; ── Track layout: oval circuit, inspired by Dust Racing 2D tile approach ──
; Road is built from StaticBody2D walls (inner + outer boundary) around an oval.
; Track width: 120px. Outer oval: 900×580. Inner oval: 660×340.
; Three question zones placed on straights and one on each long corner.

[sub_resource type="RectangleShape2D" id="wall_top_out"]
size = Vector2(900, 20)

[sub_resource type="RectangleShape2D" id="wall_bot_out"]

[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/upgrade_shop.gd" id="1_shop"]

[node name="UpgradeShop" type="Control"]
script = ExtResource("1_shop")
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0

[node name="Background" type="ColorRect" parent="."]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
color = Color(0.102, 0.102, 0.18, 1)

; Full-screen VBox with safe margins
[node name="VBox" type="VBoxContainer" parent="."]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
offset_left = 16.0
offset_top = 16.0
offset_right = -16.0
offset_bottom = -16.0
theme_override_constants/separation = 10

[node name="BackBtn" type="Button" parent="VBox"]
layout_mode = 2
custom_minimum_size = Vector2(0, 48)
text = "← Back to Menu"
theme_override_font_sizes/font_size = 18

[node name="Title" type="Label" parent="VBox"]
layout_mode = 2
text = "Upgrade Shop"
horizontal_alignment = 1
add_theme_font_size_override = "font_size"
theme_override_font_sizes/font_size = 32
theme_override_colors/font_color = Color(1.0, 0.85, 0.0, 1)

[node name="CoinsLabel" type="Label" parent="VBox"]
layout_mode = 2
text = "🪙 0 coins available"
horizontal_alignment = 1
add_theme_font_size_override = "font_size"
theme_override_font_sizes/font_size = 20

; ScrollContainer so item list is scrollable on all screen sizes
[node name="ScrollContainer" type="ScrollContainer" parent="VBox"]
layout_mode = 2
size_flags_vertical = 3

[node name="ItemList" type="VBoxContainer" parent="VBox/ScrollContainer"]
layout_mode = 2
size_flags_horizontal = 3
theme_override_constants/separation = 8

; Items are generated at runtime by upgrade_shop.gd

offset_right = 130.0
offset_bottom = -20.0
text = "◄"
modulate = Color(1, 1, 1, 0.65)
theme_override_font_sizes/font_size = 36

[node name="TurnRightBtn" type="Button" parent="TouchControls"]
anchor_left = 0.0
